{
  "name": "git-rescue",
  "displayName": "GitRescue",
  "description": "Detects git errors and fixes them with one click. For developers who don't want to learn git syntax.",
  "version": "0.5.0",
  "publisher": "rish106-hub",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "error",
    "fix",
    "beginner",
    "student"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "gitrescue.viewFixes",
        "title": "GitRescue: View My Fixes"
      },
      {
        "command": "gitrescue.undoLastCommit",
        "title": "GitRescue: Undo Last Commit"
      },
      {
        "command": "gitrescue.forcePush",
        "title": "GitRescue: Force Push (safe)"
      },
      {
        "command": "gitrescue.viewLog",
        "title": "GitRescue: View Activity Log"
      },
      {
        "command": "gitrescue.clearLog",
        "title": "GitRescue: Clear Activity Log"
      },
      {
        "command": "gitrescue.checkNow",
        "title": "GitRescue: Check Repository Now"
      },
      {
        "command": "gitrescue.explainError",
        "title": "GitRescue: Explain a Git Error"
      },
      {
        "command": "gitrescue.ask",
        "title": "GitRescue: Ask (describe it or paste an error)"
      },
      {
        "command": "gitrescue.setGroqKey",
        "title": "GitRescue: Set Groq API Key"
      },
      {
        "command": "gitrescue.clearGroqKey",
        "title": "GitRescue: Clear Groq API Key"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitrescue",
          "title": "GitRescue",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "gitrescue": [
        {
          "id": "gitrescueView",
          "name": "GitRescue"
        },
        {
          "id": "gitrescueChat",
          "name": "Ask AI",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "GitRescue",
      "properties": {
        "gitrescue.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Offer automatic recovery prompts for known Git states. Git Companion sidebar guidance is always available."
        },
        "gitrescue.disabledHandlers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Handler IDs to disable (e.g. \"h8-branch-diverged\"). Disabled handlers never auto-detect. Run \"GitRescue: View My Fixes\" to see IDs.",
          "examples": [
            [
              "h8-branch-diverged",
              "h10-far-behind-remote"
            ]
          ]
        },
        "gitrescue.telemetry": {
          "type": "boolean",
          "default": true,
          "description": "Record which fixes you use, stored locally only (handler id + timestamp). Nothing is sent over the network."
        },
        "gitrescue.confirmSafeFixes": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before applying non-destructive fixes. Destructive fixes always require two-step confirmation regardless of this setting."
        },
        "gitrescue.aiChat.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the AI chat panel (Ask AI). It uses your own Groq API key and can propose git commands; state-changing commands always require two-step confirmation and dangerous ones are never run automatically."
        },
        "gitrescue.groqModel": {
          "type": "string",
          "default": "llama-3.3-70b-versatile",
          "description": "Groq model used by the AI chat panel. See https://console.groq.com/docs/models for options."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "dev": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "gen:icon": "node scripts/gen-icon.js",
    "test:realgit": "vitest run test/realgit",
    "test:coverage": "vitest run --coverage",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run test/unit",
    "compile:test": "tsc -p tsconfig.test.json",
    "pretest:integration": "npm run compile:test",
    "test:integration": "node ./test/integration/runTests.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rish106-hub/gitdoc.git"
  },
  "homepage": "https://github.com/rish106-hub/gitdoc#readme",
  "bugs": {
    "url": "https://github.com/rish106-hub/gitdoc/issues"
  },
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "license": "MIT"
}
