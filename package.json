{
  "name": "gitdoc",
  "displayName": "GitDoc",
  "description": "Detects git errors and fixes them with one click. For developers who don't want to learn git syntax.",
  "version": "0.1.0",
  "publisher": "rish106-hub",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "error",
    "fix",
    "beginner",
    "student"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "gitdoc.viewFixes",
        "title": "GitDoc: View My Fixes"
      },
      {
        "command": "gitdoc.undoLastCommit",
        "title": "GitDoc: Undo Last Commit"
      },
      {
        "command": "gitdoc.forcePush",
        "title": "GitDoc: Force Push (safe)"
      },
      {
        "command": "gitdoc.viewLog",
        "title": "GitDoc: View Activity Log"
      },
      {
        "command": "gitdoc.clearLog",
        "title": "GitDoc: Clear Activity Log"
      },
      {
        "command": "gitdoc.checkNow",
        "title": "GitDoc: Check Repository Now"
      },
      {
        "command": "gitdoc.explainError",
        "title": "GitDoc: Explain a Git Error"
      }
    ],
    "configuration": {
      "title": "GitDoc",
      "properties": {
        "gitdoc.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically watch the repository and offer fixes when a known git problem is detected."
        },
        "gitdoc.disabledHandlers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Handler IDs to disable (e.g. \"h8-branch-diverged\"). Disabled handlers never auto-detect. Run \"GitDoc: View My Fixes\" to see IDs.",
          "examples": [
            [
              "h8-branch-diverged",
              "h10-merge-wizard"
            ]
          ]
        },
        "gitdoc.telemetry": {
          "type": "boolean",
          "default": true,
          "description": "Record which fixes you use, stored locally only (handler id + timestamp). Nothing is sent over the network."
        },
        "gitdoc.confirmSafeFixes": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before applying non-destructive fixes. Destructive fixes always require two-step confirmation regardless of this setting."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "dev": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "gen:icon": "node scripts/gen-icon.js",
    "test:realgit": "vitest run test/realgit",
    "test:coverage": "vitest run --coverage",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run test/unit",
    "compile:test": "tsc -p tsconfig.test.json",
    "pretest:integration": "npm run compile:test",
    "test:integration": "node ./test/integration/runTests.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rish106-hub/gitdoc.git"
  },
  "homepage": "https://github.com/rish106-hub/gitdoc#readme",
  "bugs": {
    "url": "https://github.com/rish106-hub/gitdoc/issues"
  },
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "license": "MIT"
}
